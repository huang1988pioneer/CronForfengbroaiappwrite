APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_DATABASE_ID=your_database_id
APPWRITE_API_KEY=your_api_key

# full: keep every run's collection JSON under data/history
# summary: keep only summary.json history and latest collection JSON
APPWRITE_SNAPSHOT_HISTORY=full
